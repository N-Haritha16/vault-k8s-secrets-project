# Vault configuration
VAULT_ADDR=http://vault.vault.svc:8200
VAULT_NAMESPACE=
VAULT_TOKEN=

# Kubernetes configuration (used by scripts / tests)
KUBE_CONTEXT=kind-vault-demo
KUBE_NAMESPACE=vault

# Database configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=appdb
DB_ADMIN_USER=vaultadmin
DB_ADMIN_PASSWORD=vaultadminpass

# Application configuration
APP_PORT=3000
APP_ENV=development

# Feature flags
ENABLE_TRANSIT_TESTS=true
ENABLE_MONITORING=false
